apiVersion: v1
kind: Secret
metadata:
  name: flight-postgres-credentials
  namespace: airport
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: postgres
  POSTGRES_DB: flight_db
---
apiVersion: v1
kind: Secret
metadata:
  name: booking-postgres-credentials
  namespace: airport
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: postgres
  POSTGRES_DB: booking_db
---
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-postgres-credentials
  namespace: airport
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: postgres
  POSTGRES_DB: keycloak_db
---
apiVersion: v1
kind: Secret
metadata:
  name: rabbitmq-credentials
  namespace: airport
type: Opaque
stringData:
  RABBITMQ_DEFAULT_USER: guest
  RABBITMQ_DEFAULT_PASS: guest
---
apiVersion: v1
kind: Secret
metadata:
  name: keycloak-credentials
  namespace: airport
type: Opaque
stringData:
  KEYCLOAK_ADMIN: admin
  KEYCLOAK_ADMIN_PASSWORD: admin
  KC_DB_USERNAME: postgres
  KC_DB_PASSWORD: postgres
---
apiVersion: v1
kind: Secret
metadata:
  name: app-secrets
  namespace: airport
type: Opaque
stringData:
  Keycloak__ClientSecret: <your-keycloak-client-secret>
  RabbitMQ__Username: guest
  RabbitMQ__Password: guest
---
apiVersion: v1
kind: Secret
metadata:
  name: flight-db-secret
  namespace: airport
type: Opaque
stringData:
  ConnectionStrings__DefaultConnection: "Host=flight-postgres;Port=5432;Database=flight_db;Username=postgres;Password=postgres"
---
apiVersion: v1
kind: Secret
metadata:
  name: booking-db-secret
  namespace: airport
type: Opaque
stringData:
  ConnectionStrings__DefaultConnection: "Host=booking-postgres;Port=5432;Database=booking_db;Username=postgres;Password=postgres"
---
apiVersion: v1
kind: Secret
metadata:
  name: mysql-credentials
  namespace: airport
type: Opaque
stringData:
  MYSQL_ROOT_PASSWORD: rootpassword
  MYSQL_DATABASE: payment_db
  MYSQL_USER: payment
  MYSQL_PASSWORD: payment_password
---
apiVersion: v1
kind: Secret
metadata:
  name: payment-secrets
  namespace: airport
type: Opaque
stringData:
  STRIPE_SECRET_KEY: <your-stripe-secret-key>
---
# ── Baggage service (moved from baggage namespace) ───────────────────────────
apiVersion: v1
kind: Secret
metadata:
  name: baggage-postgres-credentials
  namespace: airport
type: Opaque
stringData:
  POSTGRES_USER: postgres
  POSTGRES_PASSWORD: postgres
  POSTGRES_DB: baggage_db
---
apiVersion: v1
kind: Secret
metadata:
  name: baggage-secrets
  namespace: airport
type: Opaque
stringData:
  ConnectionStrings__DefaultConnection: "Host=baggage-postgres;Port=5432;Database=baggage_db;Username=postgres;Password=postgres"
  RabbitMQ__Username: guest
  RabbitMQ__Password: guest
