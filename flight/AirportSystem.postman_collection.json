  "item": [
    {
      "name": "Auth",
      "item": [
        {
          "name": "Register \u2013 New Passenger",
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}",
              "host": [
                "{{gatewayUrl}}"
              ]
            },
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Register($input: RegisterInput!) {\n  register(input: $input) {\n    accessToken\n    expiresIn\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"username\": \"passenger_{{$timestamp}}\",\n    \"email\": \"{{passengerEmail}}\",\n    \"password\": \"{{passengerPassword}}\",\n    \"role\": \"Passenger\"\n  }\n}"
              }
            }
          },
          "event": [
            {
              "listen": "prerequest",
              "script": {
                "exec": [
                  "var ts = Date.now();",
                  "pm.collectionVariables.set('passengerEmail', 'passenger_' + ts + '@example.com');",
                  "pm.collectionVariables.set('passengerPassword', 'Test1234!');"
                ]
              }
            },
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json().data;",
                  "if (data && data.register && data.register.accessToken) {",
                  "    pm.collectionVariables.set('passengerToken', data.register.accessToken);",
                  "    pm.test('Passenger registered', () => pm.expect(data.register.accessToken).to.not.be.empty);",
                  "} else {",
                  "    pm.test('Register skipped (user exists) \u2014 run Login-Passenger instead', () => true);",
                  "}"
                ]
              }
            }
          ]
        },
        {
          "name": "Login \u2013 Passenger",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var data = pm.response.json().data;",
                  "if (data && data.login && data.login.accessToken) {",
                  "    pm.collectionVariables.set('passengerToken', data.login.accessToken);",
                  "    pm.test('Got passenger token', () => pm.expect(data.login.accessToken).to.not.be.empty);",
                  "}"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}",
              "host": [
                "{{gatewayUrl}}"
              ]
            },
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"{{passengerEmail}}\",\n    \"password\": \"{{passengerPassword}}\"\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Login \u2013 Staff",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var token = pm.response.json().data.login.accessToken;",
                  "pm.collectionVariables.set('staffToken', token);",
                  "pm.test('Got staff token', () => pm.expect(token).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}",
              "host": [
                "{{gatewayUrl}}"
              ]
            },
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"staff@airport.local\",\n    \"password\": \"Staff1234!\"\n  }\n}"
              }
            }
          }
        },
        {
          "name": "Login \u2013 Admin",
          "event": [
            {
              "listen": "test",
              "script": {
                "exec": [
                  "var token = pm.response.json().data.login.accessToken;",
                  "pm.collectionVariables.set('adminToken', token);",
                  "pm.test('Got admin token', () => pm.expect(token).to.not.be.empty);"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              {
                "key": "Content-Type",
                "value": "application/json"
              }
            ],
            "url": {
              "raw": "{{gatewayUrl}}",
              "host": [
                "{{gatewayUrl}}"
              ]
            },
            "body": {
              "mode": "graphql",
              "graphql": {
                "query": "mutation Login($input: LoginInput!) {\n  login(input: $input) {\n    accessToken\n    refreshToken\n    expiresIn\n  }\n}",
                "variables": "{\n  \"input\": {\n    \"email\": \"admin@airport.local\",\n    \"password\": \"Admin1234!\"\n  }\n}"
              }
            }
