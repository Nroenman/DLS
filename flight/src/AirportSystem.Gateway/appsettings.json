{
  "Keycloak": {
    "BaseUrl": "http://keycloak:8080",
    "Realm": "airport-system"
  },
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning",
      "Yarp.ReverseProxy": "Warning"
    }
  },
  "AllowedHosts": "*",

  // ── Routing ────────────────────────────────────────────────────────────────
  // Add a new Route + Cluster entry here when another service joins the system.
  // Routes are matched top-to-bottom; more-specific paths should come first.
  //
  // Example — adding a boarding service later:
  //   "Routes": {
  //     "boarding-service": {
  //       "ClusterId": "boarding-service",
  //       "Match": { "Path": "/boarding/{**catch-all}" }
  //     },
  //     "airport-api": { ... }               ← catch-all stays last
  //   }
"ReverseProxy": {
  "Routes": {
    "booking-service": {
      "ClusterId": "booking-service",
      "Match": {
        "Path": "/api/Booking/{**catch-all}"
      },
      "Transforms": [
        { "RequestHeaderOriginalHost": "true" },
        { "X-Forwarded": "Set" }
      ]
    },
    "payment-service": {
      "ClusterId": "payment-service",
      "Match": {
        "Path": "/api/payment/{**catch-all}"
      },
      "Transforms": [
        { "RequestHeaderOriginalHost": "true" },
        { "X-Forwarded": "Set" }
      ]
    },
    "airport-api": {
      "ClusterId": "airport-api",
      "Match": {
        "Path": "{**catch-all}"
      },
      "Transforms": [
        { "RequestHeaderOriginalHost": "true" },
        { "X-Forwarded": "Set" }
      ]
    }
  },
  "Clusters": {
    "booking-service": {
      "Destinations": {
        "primary": {
          "Address": "http://booking:8080/"
        }
      }
    },
    "payment-service": {
      "Destinations": {
        "primary": {
          "Address": "http://payment:3000/"
        }
      }
    },
    "airport-api": {
      "Destinations": {
        "primary": {
          "Address": "http://flight:8080/"
        }
      }
    }
  }
}
}
